<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>MR.GOMITAS 🍬 Tienda de Dulces</title>
<link href="https://fonts.googleapis.com/css2?family=Boogaloo&family=Nunito:wght@400;600;700;800;900&display=swap" rel="stylesheet">
<style>
  :root {
    --pink: #FF6B9D;
    --purple: #C77DFF;
    --yellow: #FFD93D;
    --green: #6BCB77;
    --orange: #FF9A3C;
    --blue: #4ECDC4;
    --red: #FF4757;
    --dark: #1a1a2e;
    --dark2: #16213e;
    --card-bg: #ffffff12;
    --text: #fff;
    --text-muted: #ccc;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    font-family: 'Nunito', sans-serif;
    background: var(--dark);
    color: var(--text);
    min-height: 100vh;
    overflow-x: hidden;
  }

  /* Fondo animado */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background: 
      radial-gradient(ellipse at 10% 20%, #FF6B9D22 0%, transparent 50%),
      radial-gradient(ellipse at 90% 80%, #C77DFF22 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, #FFD93D11 0%, transparent 70%);
    pointer-events: none;
    z-index: 0;
  }

  /* Partículas flotantes */
  .particles { position: fixed; inset: 0; pointer-events: none; z-index: 0; overflow: hidden; }
  .particle {
    position: absolute;
    font-size: 1.5rem;
    animation: floatUp linear infinite;
    opacity: 0.15;
  }
  @keyframes floatUp {
    0% { transform: translateY(110vh) rotate(0deg); opacity: 0; }
    10% { opacity: 0.15; }
    90% { opacity: 0.15; }
    100% { transform: translateY(-10vh) rotate(360deg); opacity: 0; }
  }

  /* HEADER */
  header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26,26,46,0.92);
    backdrop-filter: blur(20px);
    border-bottom: 2px solid var(--pink);
    padding: 0 2rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 70px;
    box-shadow: 0 4px 30px #FF6B9D33;
  }

  .logo {
    font-family: 'Boogaloo', cursive;
    font-size: 2.2rem;
    background: linear-gradient(135deg, var(--pink), var(--yellow), var(--orange));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    letter-spacing: 2px;
  }

  nav { display: flex; gap: 0.5rem; }
  .nav-btn {
    background: none;
    border: none;
    color: var(--text-muted);
    font-family: 'Nunito', sans-serif;
    font-size: 0.95rem;
    font-weight: 700;
    cursor: pointer;
    padding: 0.4rem 1rem;
    border-radius: 20px;
    transition: all 0.25s;
    letter-spacing: 0.5px;
  }
  .nav-btn:hover, .nav-btn.active {
    background: var(--pink);
    color: white;
    box-shadow: 0 0 15px var(--pink);
  }

  .cart-icon {
    position: relative;
    background: linear-gradient(135deg, var(--pink), var(--purple));
    border: none;
    color: white;
    font-size: 1.4rem;
    width: 48px; height: 48px;
    border-radius: 50%;
    cursor: pointer;
    transition: transform 0.2s;
    display: flex; align-items: center; justify-content: center;
    box-shadow: 0 0 20px #FF6B9D55;
  }
  .cart-icon:hover { transform: scale(1.1); }
  .cart-badge {
    position: absolute;
    top: -4px; right: -4px;
    background: var(--yellow);
    color: var(--dark);
    font-size: 0.65rem;
    font-weight: 900;
    width: 20px; height: 20px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    display: none;
  }

  /* HERO */
  .hero {
    text-align: center;
    padding: 5rem 2rem 4rem;
    position: relative;
  }
  .hero h1 {
    font-family: 'Boogaloo', cursive;
    font-size: clamp(3rem, 8vw, 6rem);
    line-height: 1;
    background: linear-gradient(135deg, var(--pink) 0%, var(--yellow) 50%, var(--orange) 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    margin-bottom: 1rem;
    animation: titlePop 0.8s cubic-bezier(0.34,1.56,0.64,1);
  }
  @keyframes titlePop {
    from { transform: scale(0.5); opacity: 0; }
    to { transform: scale(1); opacity: 1; }
  }

  /* Resto de los estilos se mantienen iguales para conservar la estética */
  .section { display: none; padding: 2rem; max-width: 1300px; margin: 0 auto; }
  .section.active { display: block; }
  .section-title { font-family: 'Boogaloo', cursive; font-size: 2.2rem; margin-bottom: 2rem; display: flex; align-items: center; gap: 0.75rem; }
  .filters { display: flex; gap: 0.6rem; flex-wrap: wrap; margin-bottom: 2rem; }
  .filter-btn { padding: 0.4rem 1.2rem; border-radius: 20px; border: 2px solid transparent; background: var(--card-bg); color: var(--text-muted); font-family: 'Nunito', sans-serif; font-weight: 700; font-size: 0.85rem; cursor: pointer; transition: all 0.2s; }
  .filter-btn:hover, .filter-btn.active { border-color: var(--pink); color: white; background: #FF6B9D22; }
  .product-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1.5rem; }
  .product-card { background: linear-gradient(145deg, rgba(255,255,255,0.08), rgba(255,255,255,0.03)); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; overflow: hidden; cursor: pointer; transition: transform 0.3s, box-shadow 0.3s; animation: cardPop 0.4s cubic-bezier(0.34,1.56,0.64,1) both; }
  @keyframes cardPop { from { transform: scale(0.8); opacity: 0; } to { transform: scale(1); opacity: 1; } }
  .product-card:hover { transform: translateY(-8px) scale(1.02); box-shadow: 0 20px 60px rgba(255,107,157,0.3); }
  .product-img { width: 100%; height: 160px; display: flex; align-items: center; justify-content: center; font-size: 5rem; position: relative; overflow: hidden; }
  .product-emoji { z-index: 1; animation: wobble 2s ease-in-out infinite; }
  @keyframes wobble { 0%, 100% { transform: rotate(-5deg) scale(1); } 50% { transform: rotate(5deg) scale(1.1); } }
  .product-badge { position: absolute; top: 10px; right: 10px; background: var(--yellow); color: var(--dark); font-size: 0.65rem; font-weight: 900; padding: 2px 8px; border-radius: 10px; z-index: 2; text-transform: uppercase; letter-spacing: 1px; }
  .product-info { padding: 1rem; }
  .product-name { font-weight: 800; font-size: 1rem; margin-bottom: 0.2rem; }
  .product-category { font-size: 0.75rem; color: var(--text-muted); margin-bottom: 0.6rem; }
  .product-price { font-family: 'Boogaloo', cursive; font-size: 1.3rem; color: var(--yellow); }
  .add-btn { background: linear-gradient(135deg, var(--pink), var(--purple)); border: none; color: white; width: 36px; height: 36px; border-radius: 50%; font-size: 1.2rem; cursor: pointer; transition: transform 0.2s, box-shadow 0.2s; display: flex; align-items: center; justify-content: center; font-weight: 900; }
  .add-btn:hover { transform: scale(1.15); box-shadow: 0 0 15px var(--pink); }

  /* MODALES Y CARRITO */
  .modal-overlay { display: none; position: fixed; inset: 0; background: rgba(0,0,0,0.7); backdrop-filter: blur(8px); z-index: 200; align-items: center; justify-content: center; }
  .modal-overlay.open { display: flex; }
  .modal { background: linear-gradient(145deg, #1e1e3a, #16213e); border: 1px solid rgba(255,255,255,0.15); border-radius: 28px; padding: 2rem; max-width: 480px; width: 90%; position: relative; animation: modalPop 0.4s cubic-bezier(0.34,1.56,0.64,1); }
  .modal-close { position: absolute; top: 1rem; right: 1rem; background: rgba(255,255,255,0.1); border: none; color: white; width: 36px; height: 36px; border-radius: 50%; font-size: 1.1rem; cursor: pointer; }
  .add-to-cart-btn { width: 100%; padding: 0.9rem; background: linear-gradient(135deg, var(--pink), var(--purple)); border: none; color: white; font-weight: 900; border-radius: 14px; cursor: pointer; }
  
  /* CART */
  .cart-item { background: rgba(255,255,255,0.05); border-radius: 16px; padding: 1rem; display: flex; align-items: center; gap: 1rem; margin-bottom: 1rem; }
  .cart-total { display: flex; justify-content: space-between; font-family: 'Boogaloo', cursive; font-size: 1.5rem; margin-top: 1rem; color: var(--yellow); }
  
  /* UBICACIONES */
  .location-card { background: linear-gradient(145deg, rgba(255,255,255,0.07), rgba(255,255,255,0.03)); border: 1px solid rgba(255,255,255,0.1); border-radius: 20px; padding: 1.5rem; transition: transform 0.3s; }
  .type-regional { background: rgba(78,205,196,0.2); color: var(--blue); padding: 2px 8px; border-radius: 8px; font-size: 0.7rem; }

  .toast { position: fixed; bottom: 2rem; right: 2rem; background: var(--green); color: white; padding: 0.9rem 1.5rem; border-radius: 14px; font-weight: 800; transform: translateY(100px); opacity: 0; transition: all 0.4s; }
  .toast.show { transform: translateY(0); opacity: 1; }
</style>
</head>
<body>

<div class="particles" id="particles"></div>

<header>
  <div class="logo">🍬 MR.GOMITAS</div>
  <nav>
    <button class="nav-btn active" onclick="showSection('productos')">Productos</button>
    <button class="nav-btn" onclick="showSection('ubicaciones')">Ubicaciones</button>
  </nav>
  <button class="cart-icon" onclick="showSection('carrito')" title="Carrito">
    🛒
    <span class="cart-badge" id="cartBadge">0</span>
  </button>
</header>

<main>
  <section class="section active" id="sec-productos">
    <div class="hero">
      <h1>¡El Mundo de MR.GOMITAS!</h1>
      <p>Los sabores más deliciosos de Colombia 🇨🇴 — Directo de nuestra fábrica a tu corazón</p>
    </div>

    <div class="filters" id="filters">
      <button class="filter-btn active" onclick="filterProducts('all', this)">🍬 Todos</button>
      <button class="filter-btn" onclick="filterProducts('ositos', this)">🐻 Ositos</button>
      <button class="filter-btn" onclick="filterProducts('frutas', this)">🍓 Frutas</button>
      <button class="filter-btn" onclick="filterProducts('acidas', this)">⚡ Ácidas</button>
      <button class="filter-btn" onclick="filterProducts('premium', this)">✨ Premium</button>
    </div>

    <div class="product-grid" id="productGrid"></div>
  </section>

  <section class="section" id="sec-carrito">
    <h2 class="section-title">🛒 Mi Carrito - MR.GOMITAS</h2>
    <div id="cartContent"></div>
  </section>

  <section class="section" id="sec-ubicaciones">
    <h2 class="section-title">📍 Encuentra a MR.GOMITAS</h2>
    <div class="location-grid" id="locationGrid"></div>
  </section>
</main>

<div class="modal-overlay" id="productModal">
  <div class="modal">
    <button class="modal-close" onclick="closeModal()">✕</button>
    <span class="modal-emoji" id="modalEmoji" style="font-size: 5rem; text-align: center; display: block;"></span>
    <h2 class="modal-title" id="modalTitle" style="font-family:'Boogaloo'; font-size: 2rem;"></h2>
    <p id="modalDesc" style="color:var(--text-muted); margin: 1rem 0;"></p>
    <div class="qty-control" style="display:flex; align-items:center; gap:1rem; margin-bottom:1.5rem;">
      <button class="nav-btn" style="background:var(--pink); color:white; width:40px; height:40px; border-radius:50%;" onclick="changeQty(-1)">-</button>
      <span id="qtyNum" style="font-size:1.5rem; font-weight:bold;">1</span>
      <button class="nav-btn" style="background:var(--pink); color:white; width:40px; height:40px; border-radius:50%;" onclick="changeQty(1)">+</button>
      <span id="modalTotal" style="margin-left:auto; color:var(--yellow); font-family:'Boogaloo'; font-size:1.5rem;"></span>
    </div>
    <button class="add-to-cart-btn" onclick="addFromModal()">🛒 Agregar al Pedido</button>
  </div>
</div>

<div class="modal-overlay" id="checkoutModal">
  <div class="modal" style="text-align:center;">
    <span style="font-size:4rem;">🎉</span>
    <h2 style="font-family:'Boogaloo'; font-size:2rem;">¡Gracias por preferir a MR.GOMITAS!</h2>
    <p style="color:var(--text-muted); margin:1rem 0;">Tu pedido ha sido recibido con éxito.</p>
    <button class="add-to-cart-btn" onclick="closeCheckout()">Volver a la tienda</button>
  </div>
</div>

<div class="toast" id="toast"></div>

<script>
// Datos (Se mantienen los mismos de tu archivo original)
const products = [
  { id:1, name:'Ositos Clásicos', emoji:'🐻', category:'ositos', weight:'200g', price:3500, color:'#FF6B9D', badge:'Popular', desc:'Los ositos favoritos de MR.GOMITAS. Suaves y jugosos.' },
  { id:2, name:'Anillos de Sandía', emoji:'🍉', category:'frutas', weight:'250g', price:4200, color:'#6BCB77', badge:null, desc:'Dulces anillos con sabor a sandía natural.' },
  { id:3, name:'Gusanos Ácidos', emoji:'🐛', category:'acidas', weight:'200g', price:3800, color:'#FFD93D', badge:'Top', desc:'¡Explosión de sabor ácido!' },
  { id:4, name:'Fresas Rellenas', emoji:'🍓', category:'rellenas', weight:'250g', price:5500, color:'#FF4757', badge:'Nuevo', desc:'Gomitas de fresa con relleno cremoso.' },
  { id:5, name:'Mix Premium', emoji:'🌈', category:'premium', weight:'400g', price:9000, color:'#4ECDC4', badge:'Premium', desc:'Lo mejor de nuestra selección.' },
  { id:6, name:'Box Surtida 1kg', emoji:'🎁', category:'premium', weight:'1kg', price:18000, color:'#FF6B9D', badge:'⭐ Oferta', desc:'El regalo perfecto para los amantes del dulce.' },
];

const locations = [
  { name:'Bogotá Principal', icon:'🏙️', type:'central', typeLabel:'Planta', address:'Zona Industrial, Bogotá', phone:'+57 1 234 5678', schedule:'Lun-Vie 8am-6pm' },
  { name:'Medellín Centro', icon:'⛰️', type:'regional', typeLabel:'Tienda', address:'El Poblado, Medellín', phone:'+57 4 567 8901', schedule:'Lun-Sáb 9am-8pm' },
];

let cart = [];
let currentProduct = null;
let currentQty = 1;

function initParticles() {
  const container = document.getElementById('particles');
  const emojis = ['🍬','🐻','🍓','⭐'];
  for (let i = 0; i < 15; i++) {
    const el = document.createElement('div');
    el.className = 'particle';
    el.textContent = emojis[Math.floor(Math.random() * emojis.length)];
    el.style.left = Math.random() * 100 + '%';
    el.style.animationDuration = (8 + Math.random() * 10) + 's';
    container.appendChild(el);
  }
}

function showSection(name) {
  document.querySelectorAll('.section').forEach(s => s.classList.remove('active'));
  document.getElementById('sec-' + name).classList.add('active');
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  if (name === 'carrito') renderCart();
  if (name === 'ubicaciones') renderLocations();
  window.scrollTo({ top: 0, behavior: 'smooth' });
}

function renderProducts(filter = 'all') {
  const grid = document.getElementById('productGrid');
  const filtered = filter === 'all' ? products : products.filter(p => p.category === filter);
  grid.innerHTML = filtered.map(p => `
    <div class="product-card" onclick="openModal(${p.id})">
      <div class="product-img" style="background:${p.color}22">
        <span class="product-emoji">${p.emoji}</span>
        ${p.badge ? `<span class="product-badge">${p.badge}</span>` : ''}
      </div>
      <div class="product-info">
        <div class="product-name">${p.name}</div>
        <div class="product-price">$${p.price.toLocaleString('es-CO')}</div>
        <div class="product-footer" style="margin-top:0.5rem">
           <span style="font-size:0.8rem; color:var(--text-muted)">${p.weight}</span>
           <button class="add-btn" onclick="event.stopPropagation(); quickAdd(${p.id})">+</button>
        </div>
      </div>
    </div>
  `).join('');
}

function filterProducts(cat, btn) {
  document.querySelectorAll('.filter-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderProducts(cat);
}

function openModal(id) {
  currentProduct = products.find(p => p.id === id);
  currentQty = 1;
  document.getElementById('modalEmoji').textContent = currentProduct.emoji;
  document.getElementById('modalTitle').textContent = currentProduct.name;
  document.getElementById('modalDesc').textContent = currentProduct.desc;
  document.getElementById('qtyNum').textContent = "1";
  updateModalTotal();
  document.getElementById('productModal').classList.add('open');
}

function closeModal() { document.getElementById('productModal').classList.remove('open'); }

function changeQty(delta) {
  currentQty = Math.max(1, currentQty + delta);
  document.getElementById('qtyNum').textContent = currentQty;
  updateModalTotal();
}

function updateModalTotal() {
  document.getElementById('modalTotal').textContent = `$${(currentProduct.price * currentQty).toLocaleString('es-CO')}`;
}

function addFromModal() {
  addToCart(currentProduct, currentQty);
  closeModal();
}

function quickAdd(id) {
  const p = products.find(x => x.id === id);
  addToCart(p, 1);
}

function addToCart(product, qty) {
  const existing = cart.find(i => i.id === product.id);
  if (existing) existing.qty += qty;
  else cart.push({ ...product, qty });
  updateBadge();
  showToast(`¡${product.name} añadido a MR.GOMITAS!`);
}

function updateBadge() {
  const total = cart.reduce((s, i) => s + i.qty, 0);
  const badge = document.getElementById('cartBadge');
  badge.textContent = total;
  badge.style.display = total > 0 ? 'flex' : 'none';
}

function renderCart() {
  const el = document.getElementById('cartContent');
  if (cart.length === 0) {
    el.innerHTML = `<div style="text-align:center; padding:3rem;"><h3>Tu carrito MR.GOMITAS está vacío 🐻</h3></div>`;
    return;
  }
  const total = cart.reduce((s, i) => s + i.price * i.qty, 0);
  el.innerHTML = `
    <div class="cart-items">
      ${cart.map(item => `
        <div class="cart-item">
          <span style="font-size:2rem">${item.emoji}</span>
          <div style="flex:1"><b>${item.name}</b><br><small>${item.qty} x $${item.price}</small></div>
          <div style="color:var(--yellow)">$${(item.price * item.qty).toLocaleString('es-CO')}</div>
        </div>
      `).join('')}
    </div>
    <div class="cart-total"><span>Total del Pedido:</span> <span>$${total.toLocaleString('es-CO')}</span></div>
    <button class="add-to-cart-btn" style="margin-top:2rem; background:var(--green)" onclick="checkout()">Finalizar Compra</button>
  `;
}

function checkout() { document.getElementById('checkoutModal').classList.add('open'); }

function closeCheckout() {
  cart = [];
  updateBadge();
  document.getElementById('checkoutModal').classList.remove('open');
  showSection('productos');
}

function renderLocations() {
  const grid = document.getElementById('locationGrid');
  grid.innerHTML = locations.map(loc => `
    <div class="location-card">
      <span style="font-size:2rem">${loc.icon}</span>
      <h3 style="font-family:'Boogaloo'; margin:0.5rem 0;">${loc.name}</h3>
      <span class="type-regional">${loc.typeLabel}</span>
      <p style="font-size:0.8rem; color:var(--text-muted); margin-top:1rem;">
        📍 ${loc.address}<br>📞 ${loc.phone}<br>⏰ ${loc.schedule}
      </p>
    </div>
  `).join('');
}

function showToast(msg) {
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 2500);
}

// Cierre de modales al hacer clic fuera
window.onclick = function(event) {
  if (event.target.classList.contains('modal-overlay')) {
    closeModal();
    document.getElementById('checkoutModal').classList.remove('open');
  }
}

initParticles();
renderProducts();
</script>
</body>
</html>
